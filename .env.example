# Variables de entorno para el Formulario de Contacto
# Copia este archivo como .env y configura los valores reales

# Servidor
PORT=3000
NODE_ENV=development

# Configuración del servidor de correo (SMTP)
EMAIL_HOST=smtp.ejemplo.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=tu-correo@ejemplo.com
EMAIL_PASS=tu-contraseña

# Correo del destinatario de los mensajes de contacto
EMAIL_TO=destinatario@ejemplo.com
EMAIL_FROM=noreply@tu-dominio.com

# Nombre del sitio
SITE_NAME=Mi Empresa
